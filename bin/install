#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
prepare_only=false
migrate_known=false

for argument in "$@"; do
  case "$argument" in
    --prepare-only) prepare_only=true ;;
    --migrate-known) migrate_known=true ;;
    *) echo "Usage: $0 [--prepare-only] [--migrate-known]" >&2; exit 2 ;;
  esac
done

if [ "$prepare_only" = true ] && [ "$migrate_known" = true ]; then
  echo "--prepare-only cannot migrate an active older router." >&2
  exit 2
fi

platform=$(uname -s)
case "$platform" in
  Darwin|Linux) ;;
  *)
    if [ "$prepare_only" != true ]; then
      echo "Use install.ps1 for the native Windows installer." >&2
      exit 1
    fi
    ;;
esac

for tool in node npm; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "$tool is required but was not found on PATH." >&2
    exit 1
  fi
done

node -e 'const [a,b]=process.versions.node.split(".").map(Number); if (!(a>22 || (a===22 && b>=19))) { console.error("Node.js 22.19 or newer is required."); process.exit(1) }'

cd "$repo_dir"
codex_home=${CODEX_HOME:-$HOME/.codex}
mkdir -p "$codex_home"
if [ "$migrate_known" = true ]; then
  node src/legacy-migration.mjs apply --yes >/dev/null
else
  node src/legacy-migration.mjs assert-clear >/dev/null
fi
if [ "$prepare_only" != true ]; then
  node src/provider-selection.mjs ensure-configured >/dev/null
fi
npm ci --omit=dev

if command -v uv >/dev/null 2>&1; then
  if [ ! -x .venv/bin/python ]; then
    uv venv --python 3.12 .venv
  fi
  uv pip install --python .venv/bin/python 'litellm[proxy]==1.93.0'
else
  if ! command -v python3 >/dev/null 2>&1; then
    echo "Python 3.10+ or uv is required to install LiteLLM." >&2
    exit 1
  fi
  python3 -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 10) else "Python 3.10 or newer is required.")'
  python3 -m venv .venv
  .venv/bin/python -m pip install --upgrade pip
  .venv/bin/python -m pip install 'litellm[proxy]==1.93.0'
fi

node src/secret.mjs ensure
state_dir=${CODEX_ROUTER_STATE_DIR:-${KIMI_CODEX_STATE_DIR:-${CODEX_HOME:-$HOME/.codex}/codex-router}}
if [ -s "$state_dir/native-models.json" ]; then
  node src/catalog.mjs
else
  node src/catalog.mjs --refresh-native
fi
node src/litellm-config.mjs

if [ "$prepare_only" = true ]; then
  echo "Dependencies, service key, and model catalog are prepared. Codex config was not changed."
  exit 0
fi

config_enabled=false
service_installed=false
rollback() {
  if [ "$service_installed" = true ]; then
    node src/service.mjs uninstall >/dev/null 2>&1 || true
  fi
  if [ "$config_enabled" = true ]; then
    node src/config-manager.mjs disable >/dev/null 2>&1 || true
  fi
}
trap rollback EXIT HUP INT TERM

node src/config-manager.mjs enable
config_enabled=true
service_installed=true
node src/service.mjs install
node src/wait-health.mjs
node src/install-manifest.mjs record >/dev/null
config_enabled=false
service_installed=false
trap - EXIT HUP INT TERM

echo "Installed the selected external model routes for Codex."
echo "Fully quit and reopen Codex, then start a new task."
echo "Kimi API key: $repo_dir/bin/provider-key kimi-api set"
echo "DeepSeek API key: $repo_dir/bin/provider-key deepseek set"
echo "Ark Coding Plan API key: $repo_dir/bin/provider-key ark-coding set"
