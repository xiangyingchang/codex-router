#!/bin/sh
set -eu

state_dir=${KIMI_CODEX_STATE_DIR:-${CODEX_HOME:-$HOME/.codex}/kimi-router}
key_file="$state_dir/api-key.secret"
command=${1:-status}

case "$command" in
  status)
    if [ -s "$key_file" ]; then
      echo "Kimi API key is configured in the protected local key file."
    elif [ -n "${KIMI_API_KEY:-}" ] || [ -n "${MOONSHOT_API_KEY:-}" ]; then
      echo "Kimi API key is configured through the environment."
    elif [ "$(uname -s)" = "Darwin" ] && /usr/bin/security find-generic-password -s kimi-codex-api -a default >/dev/null 2>&1; then
      echo "Kimi API key is configured in macOS Keychain."
    else
      echo "Kimi API key is not configured."
      exit 1
    fi
    ;;
  set)
    if [ ! -e /dev/tty ]; then
      echo "An interactive terminal is required." >&2
      exit 1
    fi
    old_stty=$(/bin/stty -g </dev/tty)
    trap '/bin/stty "$old_stty" </dev/tty' EXIT HUP INT TERM
    printf 'Kimi Platform API key: ' >/dev/tty
    /bin/stty -echo </dev/tty
    IFS= read -r api_key </dev/tty
    /bin/stty "$old_stty" </dev/tty
    trap - EXIT HUP INT TERM
    printf '\n' >/dev/tty
    if [ -z "$api_key" ]; then
      echo "No key entered; nothing changed." >&2
      exit 1
    fi
    /bin/mkdir -p "$state_dir"
    /bin/chmod 700 "$state_dir"
    umask 077
    temporary="$key_file.tmp.$$"
    printf '%s\n' "$api_key" >"$temporary"
    /bin/chmod 600 "$temporary"
    /bin/mv -f "$temporary" "$key_file"
    unset api_key
    echo "Kimi API key saved with mode 600. No service restart is required."
    ;;
  remove)
    if [ -e "$key_file" ]; then
      /bin/rm -f "$key_file"
      echo "Removed the protected local Kimi API key file."
    else
      echo "No local Kimi API key file exists."
    fi
    ;;
  *)
    echo "Usage: $0 status|set|remove" >&2
    exit 2
    ;;
esac
