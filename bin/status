#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$repo_dir"
node src/config-manager.mjs status
if [ "$(uname -s)" = "Darwin" ]; then
  node src/service-macos.mjs status
fi
node -e 'const port=Number(process.env.KIMI_ROUTER_PORT||4102); fetch(`http://127.0.0.1:${port}/health`).then(async r=>{console.log(await r.text()); process.exitCode=r.ok?0:1}).catch(()=>{console.log(JSON.stringify({ok:false,router:"unavailable"})); process.exitCode=1})'
