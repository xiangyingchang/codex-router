#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$repo_dir"
mode=$(node src/config-manager.mjs status | node -e 'let s=""; process.stdin.on("data",d=>s+=d); process.stdin.on("end",()=>process.stdout.write(JSON.parse(s).mode))')
restore=false
if [ "$mode" = "router" ]; then
  node src/config-manager.mjs disable >/dev/null
  restore=true
fi
restore_config() {
  if [ "$restore" = true ]; then node src/config-manager.mjs enable >/dev/null 2>&1 || true; fi
}
trap restore_config EXIT HUP INT TERM
node src/catalog.mjs --refresh-native
restore_config
restore=false
trap - EXIT HUP INT TERM
echo "Native and Kimi model catalogs refreshed. Fully quit and reopen Codex."
